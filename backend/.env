APP_NAME=CamerBus
APP_ENV=development
APP_URL=http://localhost/camerbus-api
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=camerbus
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=camerbus_super_secret_jwt_key_2024_change_in_production
JWT_ACCESS_EXPIRE=900
JWT_REFRESH_EXPIRE=604800

# Pusher (Realtime)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=mt1

# Firebase (Push Notifications)
FIREBASE_SERVER_KEY=your_firebase_server_key
FIREBASE_PROJECT_ID=camerbus-app

# Google Maps
GOOGLE_MAPS_KEY=your_google_maps_api_key

# Upload
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880
ALLOWED_TYPES=image/jpeg,image/png,image/webp

# CORS
ALLOWED_ORIGINS=*
